{
    "files.watcherExclude": {
        ".cache/**": true,
        "{build,build_ut,output,artifacts,dist}/**": true,
        "**/*.egg-info/**": true,
        "**/{.venv,node_modules,__pycache__,.pytest_cache,.ruff_cache,.mypy_cache}/**": true
    },
    "search.exclude": {
        ".cache/**": true,
        "{build,build_ut,output,artifacts,dist}/**": true,
        "**/*.egg-info/**": true,
        "**/{.venv,node_modules,__pycache__,.pytest_cache,.ruff_cache,.mypy_cache}/**": true
    },
    "files.exclude": {
        ".cache": true,
        "**/*.egg-info": true,
        "**/{__pycache__,.pytest_cache,.ruff_cache,.mypy_cache}": true
    },
    "terminal.integrated.scrollback": 10000,
    "git.detectSubmodules": false,
    "git.autoRepositoryDetection": false
}
